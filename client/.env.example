# Copy this file to .env and fill in your values
# .env is gitignored — never commit real IPs or secrets

# Discovery Service endpoint (recommended)
# Should return the current leader URL as plain text, e.g. "http://100.64.0.10:8000"
# Example: Cloudflare Worker KV text endpoint, S3/Blob raw text, etc.
REACT_APP_DISCOVERY_URL=

# Fallback if discovery is unset/unreachable (useful for local dev)
REACT_APP_LEADER_FALLBACK_URL=http://localhost:8000

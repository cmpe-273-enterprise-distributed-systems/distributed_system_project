# Copy this file to .env and fill in your values
# .env is gitignored — never commit real IPs or secrets

# Discovery via Upstash Redis (recommended for multi-laptop)
# The same Upstash instance the leader publishes to. Use the READ-ONLY token —
# it will be baked into the JS bundle and visible to anyone using the app, so
# never put the read/write token here.
#
# Prerequisite: enable CORS for your client's origin in the Upstash dashboard:
#   Database → REST API → Allowed Origins → add e.g. http://localhost:3000
REACT_APP_UPSTASH_REDIS_REST_URL=
REACT_APP_UPSTASH_REDIS_REST_READ_ONLY_TOKEN=

# Fallback if discovery is unset/unreachable (useful for local dev)
REACT_APP_LEADER_FALLBACK_URL=http://localhost:8000

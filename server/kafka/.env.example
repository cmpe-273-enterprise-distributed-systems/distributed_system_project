# Environment for server/kafka/docker-compose.yml.
# Copy to server/kafka/.env and fill in the two values below.
# Only the designated Kafka host laptop runs this compose file.

# This laptop's Tailscale IP. All other laptops connect here on port 9092.
KAFKA_ADVERTISED_HOST=100.64.0.5

# Base64-encoded 16-byte UUID — shared across the cluster (must never change).
# Generate once with:
#   docker run --rm confluentinc/cp-kafka:7.5.0 kafka-storage random-uuid
KAFKA_CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qk

# Fallback leader URL. Used only when the discovery service is unconfigured or
# unreachable on startup. Once Upstash is set up, the worker resolves the current
# leader from there and updates this value at runtime.
LEADER_URL=http://localhost:8000

# Upstash Redis REST credentials — read-only token is sufficient (workers never
# write to discovery). Copy from the Upstash database details page.
# Leave both blank to use only the LEADER_URL fallback above (single-host dev).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_READ_ONLY_TOKEN=

# Kafka bootstrap servers. Comma-separated host:port list — the client connects
# to whichever broker answers first and learns the rest of the cluster.
#   Single-host dev:    localhost:9092
#   Multi-broker prod:  100.64.0.5:9092,100.64.0.6:9092,100.64.0.7:9092
KAFKA_BROKER=localhost:9092

# Ollama API base URL (default: local Ollama install)
OLLAMA_URL=http://localhost:11434

# Fallback model if Ollama is not running — must be pulled: ollama pull <model>
MODEL=mistral

# Fallback skill tags if no .skill files are found in the worker directory
SKILLS=general,coding

# Optional: override the auto-generated node ID (useful for stable node names)
NODE_ID=

# Optional: override the auto-detected RAM (in GB)
RAM_GB=

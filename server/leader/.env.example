# Kafka bootstrap servers. Comma-separated host:port list — the client connects
# to whichever broker answers first and learns the rest of the cluster.
#   Single-host dev:    localhost:9092
#   Multi-broker prod:  100.64.0.5:9092,100.64.0.6:9092,100.64.0.7:9092
KAFKA_BROKER=localhost:9092

# ── Cassandra (Astra DataStax cloud OR local docker fallback) ────────────────
# USE_ASTRA selects the connection mode:
#   true  -> connect to Astra DataStax (required for multi-laptop demo so that
#            user data + request history survive leader failover).
#   false -> connect to local docker Cassandra at LOCAL_CASSANDRA_HOST. Data is
#            leader-local and does NOT survive failover. Offline-dev only.
USE_ASTRA=true

# Astra DataStax credentials (only required when USE_ASTRA=true).
# 1. Sign up + create a serverless DB at astra.datastax.com.
# 2. Create keyspace `web_app` and apply client/db/002_tables.cql + 003_seed_data.cql
#    via the Astra console's CQL editor (skip 001_keyspace.cql — Astra creates the keyspace).
# 3. Generate an application token (Database Administrator role) → copy clientId + clientSecret.
# 4. Download the Secure Connect Bundle (.zip) and reference its path here.
# The .zip is small (~10KB) and per-database, not per-user — share privately with teammates.
# DO NOT COMMIT the bundle. .gitignore already excludes secure-connect-*.zip.
ASTRA_BUNDLE_PATH=./secrets/secure-connect-web-app.zip
ASTRA_CLIENT_ID=
ASTRA_CLIENT_SECRET=
ASTRA_KEYSPACE=web_app

# Local docker Cassandra (only used when USE_ASTRA=false).
LOCAL_CASSANDRA_HOST=127.0.0.1
LOCAL_CASSANDRA_PORT=9042
LOCAL_CASSANDRA_KEYSPACE=web_app

# Seconds to wait for a worker to return a result before timing out
TASK_TIMEOUT=60

# Upstash Redis REST credentials — copy from your Upstash database details page.
# Used as the cluster's service-discovery backend (key: "leader").
# Leave blank to fall back to local file-only mode (config/leader_url.txt).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Override what this leader advertises as its own host in /register, /heartbeat,
# and the discovery service. Auto-detection prefers Tailscale (MagicDNS, then
# IP); without Tailscale it falls back to socket.gethostname(), which on WSL2
# returns the Windows host name — resolvable but NOT reachable from the worker
# process. For single-host dev on WSL2, set this to 'localhost'. For
# cross-machine deployment without Tailscale, set this to the host's LAN IP.
LEADER_ADVERTISE_HOST=

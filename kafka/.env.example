# Per-laptop environment for kafka/docker-compose.yml.
# Copy to kafka/.env and customize the per-laptop values.

# ── Per-laptop (different on each broker host) ────────────────────────────────

# Unique numeric ID for this broker. Conventionally 1, 2, 3. Must appear in
# KAFKA_QUORUM_VOTERS below with the same number.
KAFKA_NODE_ID=1

# This laptop's Tailscale IP. Other brokers and all clients (leader, workers,
# frontend) connect to this address on port 9092.
KAFKA_ADVERTISED_HOST=100.64.0.5

# ── Shared (identical on every broker host) ───────────────────────────────────

# Base64-encoded 16-byte UUID. Generate ONCE for the cluster with:
#   docker run --rm confluentinc/cp-kafka:7.5.0 kafka-storage random-uuid
# Then paste the same value into every broker's .env.kafka.
KAFKA_CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qk

# All controller peers as <NODE_ID>@<HOST>:9093, comma-separated.
# Must include every leader-eligible laptop. Same value on every broker host.
KAFKA_QUORUM_VOTERS=1@100.64.0.5:9093,2@100.64.0.6:9093,3@100.64.0.7:9093

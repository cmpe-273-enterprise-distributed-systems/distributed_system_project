# URL of the leader node (use Tailscale IP when running on a separate machine)
LEADER_URL=http://localhost:8000

# Kafka broker on the leader machine (use Tailscale IP for cross-machine workers)
KAFKA_BROKER=localhost:9092

# Ollama API base URL (default: local Ollama install)
OLLAMA_URL=http://localhost:11434

# Fallback model if Ollama is not running — must be pulled: ollama pull <model>
MODEL=mistral

# Fallback skill tags if no .skill files are found in the worker directory
SKILLS=general,coding

# Optional: override the auto-generated node ID (useful for stable node names)
NODE_ID=

# Optional: override the auto-detected RAM (in GB)
RAM_GB=

# Kafka broker address — use localhost:9092 for local dev
# Change to your Tailscale IP when running workers on other machines
KAFKA_BROKER=localhost:9092

# Cassandra container name (must match the service in docker-compose.yml)
DB_CQLSH_CONTAINER=web-app-cassandra

# Seconds to wait for a worker to return a result before timing out
TASK_TIMEOUT=60

# Upstash Redis REST credentials — copy from your Upstash database details page.
# Used as the cluster's service-discovery backend (key: "leader").
# Leave blank to fall back to local file-only mode (config/leader_url.txt).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
